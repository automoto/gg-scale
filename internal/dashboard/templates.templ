templ PlayersPage(vm PlayersView) {
	@appLayout("Players — ggscale", vm.UserEmail, vm.CSRFToken) {
		<div class="breadcrumb">
			<a href="/v1/dashboard">Tenants</a> /
			<a href={ templ.URL("/v1/dashboard/tenants/" + stringFromInt(vm.TenantID) + "/projects") }>Projects</a> / Players
		</div>
		<div class="page-header">
			<div>
				<p class="eyebrow">Players</p>
				<h1>Players</h1>
				<p class="subtitle">Game players in project #{ stringFromInt(vm.ProjectID) }.</p>
			</div>
			<a href={ templ.URL("/v1/dashboard/tenants/" + stringFromInt(vm.TenantID) + "/projects/" + stringFromInt(vm.ProjectID) + "/players/invite") } role="button" class="btn-inline">+ Invite player</a>
		</div>
		@flashSuccess(vm.Message)
		<section class="card">
			<form method="get" action={ templ.URL("/v1/dashboard/tenants/" + stringFromInt(vm.TenantID) + "/projects/" + stringFromInt(vm.ProjectID) + "/players") }>
				<label>
					Search email
					<input name="q" type="search" value={ vm.Search } placeholder="email contains…"/>
				</label>
				<button type="submit" class="btn-inline">Search</button>
			</form>
		</section>
		<section class="card">
			if len(vm.Players) == 0 {
				<div class="empty-state"><p>No players yet.</p></div>
			} else {
				<table class="data-table">
					<thead>
						<tr>
							<th>Email</th>
							<th>External ID</th>
							<th>Verified</th>
							<th>Status</th>
							<th>Joined</th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						for _, p := range vm.Players {
							<tr>
								<td>{ p.Email }</td>
								<td><code>{ p.ExternalID }</code></td>
								<td>
									if !p.EmailVerifiedAt.IsZero() {
										<span class="badge">verified</span>
									} else {
										<span class="badge">unverified</span>
									}
								</td>
								<td>
									if !p.DisabledAt.IsZero() {
										<span class="badge">disabled</span>
									} else {
										<span class="badge badge-role">active</span>
									}
								</td>
								<td>{ timeString(p.CreatedAt) }</td>
								<td><a href={ templ.URL("/v1/dashboard/tenants/" + stringFromInt(vm.TenantID) + "/projects/" + stringFromInt(vm.ProjectID) + "/players/" + stringFromInt(p.ID)) } role="button" class="secondary outline">View</a></td>
							</tr>
						}
					</tbody>
				</table>
				<p>Showing { stringFromInt(int64(len(vm.Players))) } of { approximateTotalLabel(vm.Total, vm.HasNext) }.</p>
			}
		</section>
	}
}


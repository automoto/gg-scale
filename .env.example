# ggscale-server runtime configuration.
# Copy to .env and edit. Every variable read by code must appear here;
# config.TestEnvExample_HasNoDrift fails the build if they diverge.

# Postgres connection string (required).
# Set DATABASE_URL_FILE to read the value from a file path instead — useful
# for docker/k8s/Vault file-mounted secrets. _FILE wins when set.
DATABASE_URL=postgres://ggscale:ggscale@localhost:5432/ggscale?sslmode=disable
DATABASE_URL_FILE=

# HTTP listen address.
HTTP_ADDR=:8080

# Public IP or hostname that game clients use to reach game server containers.
# Required when FLEET_BACKEND=docker. Leave empty for local dev; set to your
# VPS public IP in production.
GAME_SERVER_PUBLIC_IP=

# Fleet allocator: docker | agones | openstack | plugin:<name>. Default docker
# matches the single-VPS self-host story.
FLEET_BACKEND=docker

# Region label stamped on every allocation and used by region-aware backends
# (Agones GameServerSelector, openstack region).
FLEET_REGION=local

# Directory scanned for ggscale-fleet-* plugin binaries. Only consulted when
# FLEET_BACKEND starts with "plugin:".
FLEET_PLUGIN_DIR=/etc/ggscale/plugins

# Per-fleet template values (Docker image+port+probe, Agones fleet name +
# selector labels) live on fleet templates managed in the dashboard at
# /v1/dashboard/tenants/<t>/projects/<p>/fleets — not in env vars.
# Operators create at least one fleet template before allocations succeed.

# Docker fleet-backend host-wide tunable. Override DOCKER_HOST when the
# daemon isn't at unix:///var/run/docker.sock.
DOCKER_HOST=

# Agones fleet-backend host-wide tunables. Only consulted when
# FLEET_BACKEND=agones.
# Kubernetes namespace where the Agones Fleet/GameServer CRs live (default
# for fleet templates that don't override "namespace").
AGONES_NAMESPACE=default
# Path to a kubeconfig file. Empty uses in-cluster config (ServiceAccount
# mounted at /var/run/secrets/kubernetes.io/serviceaccount), then falls
# back to ~/.kube/config.
AGONES_KUBECONFIG=

# Realtime WebSocket per-tenant concurrent connection cap. 0 disables the cap.
REALTIME_MAX_PER_TENANT=0

# Matchmaker tickets per match (per region/game_mode bucket). The worker
# wakes on Postgres LISTEN/NOTIFY; MATCHMAKER_INTERVAL is only the fallback
# scan that catches tickets queued during a listener reconnect.
MATCHMAKER_BUCKET_SIZE=1
MATCHMAKER_INTERVAL=5s

# TURN relay. Disabled unless RELAY_PUBLIC_IP and RELAY_SHARED_SECRET are both set.
RELAY_PUBLIC_IP=
RELAY_BIND_ADDR=0.0.0.0
RELAY_UDP_PORT=3478
RELAY_REALM=ggscale
RELAY_SHARED_SECRET=
RELAY_SHARED_SECRET_FILE=
RELAY_CRED_TTL=5m

# Log level: debug, info, warn, error.
LOG_LEVEL=info

# Deployment environment: dev, staging, prod.
ENV=dev

# Hex-encoded HMAC signing key for end-user JWTs (64+ hex chars / 32+ bytes).
# Optional in dev: a random key is generated at startup with a warning.
# Required in prod: rotation is operator-driven for now.
# Supports JWT_SIGNING_KEY_FILE — read the key from a mounted secret file.
JWT_SIGNING_KEY=
JWT_SIGNING_KEY_FILE=

# Dashboard operator UI. On a fresh install, the server logs a one-time
# bootstrap token for /v1/dashboard/setup; set a token file path if scripts
# should read it from disk instead of logs.
DASHBOARD_DISABLED=false
DASHBOARD_BOOTSTRAP_TOKEN_FILE=
DASHBOARD_COOKIE_SECURE=false
# Externally-visible origin prefixed onto invite magic links emailed from the
# dashboard. Leave empty in local dev (uses relative paths).
DASHBOARD_BASE_URL=

# Player-facing /v1/players site (signup/verify/login for game players).
PLAYERS_ENABLED=true

# Cache backend: memory (single process) or olric (embedded cluster).
CACHE_BACKEND=memory

# Olric-protocol bind address and port. Only consulted when CACHE_BACKEND=olric.
CACHE_OLRIC_BIND_ADDR=127.0.0.1
CACHE_OLRIC_BIND_PORT=3320

# Olric memberlist (gossip) bind address and port.
CACHE_OLRIC_MEMBERLIST_ADDR=127.0.0.1
CACHE_OLRIC_MEMBERLIST_PORT=3322

# Comma-separated list of host:port memberlist endpoints to join. Empty
# means form a cluster of one.
CACHE_OLRIC_PEERS=

# Mail provider: "smtp" (default) or "noop" (discard all mail).
# External providers register via mailer.Register — import their package in
# main.go and set MAIL_PROVIDER to the registered name.
MAIL_PROVIDER=smtp

# SMTP server address. Defaults to MailHog's SMTP port in the dev compose stack.
SMTP_ADDR=localhost:1025

# SMTP credentials. Leave empty for unauthenticated relays (e.g. MailHog in dev).
SMTP_USER=
SMTP_PASSWORD=

# Sender address on outbound mail.
MAIL_FROM=noreply@ggscale.dev
